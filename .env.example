# Gemini API Key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIza...

# Google Sheets ID (the long string in the sheet URL)
# e.g. https://docs.google.com/spreadsheets/d/THIS_PART_IS_THE_ID/edit
GOOGLE_SHEET_ID=your_sheet_id_here

# Google Service Account credentials (JSON file path)
# Create at: https://console.cloud.google.com/iam-admin/serviceaccounts
# Then share your Google Sheet with the service account email
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
